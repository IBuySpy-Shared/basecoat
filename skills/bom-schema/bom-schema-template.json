{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ibuyspy-shared.github.io/basecoat/skills/bom-schema/bom-schema-template.json",
  "title": "BOM Schema",
  "type": "object",
  "required": ["bomId", "items"],
  "properties": {
    "bomId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["resourceId", "name", "quantity"],
        "properties": {
          "resourceId": {
            "type": "string",
            "pattern": "^[A-Z]{2,}-[A-Z0-9-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "minimum": 1
          },
          "unit": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
