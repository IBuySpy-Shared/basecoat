{
  "dashboard": {
    "title": "Basecoat Portal Performance Baseline",
    "description": "Real-time performance monitoring for load tests (baseline, ramp-up, soak, spike, stress)",
    "tags": [
      "basecoat",
      "performance",
      "k6",
      "load-testing"
    ],
    "timezone": "browser",
    "refresh": "5s",
    "rows": [
      {
        "title": "Application Performance - Response Times",
        "height": 250,
        "panels": [
          {
            "title": "Response Time (p50, p95, p99, max)",
            "targets": [
              {
                "expr": "histogram_quantile(0.50, rate(http_request_duration_ms_bucket[5m]))",
                "legendFormat": "p50"
              },
              {
                "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
                "legendFormat": "p95"
              },
              {
                "expr": "histogram_quantile(0.99, rate(http_request_duration_ms_bucket[5m]))",
                "legendFormat": "p99"
              },
              {
                "expr": "max(http_request_duration_ms)",
                "legendFormat": "max"
              }
            ],
            "type": "graph",
            "yaxes": [
              {
                "label": "Response Time (ms)",
                "format": "short"
              }
            ]
          },
          {
            "title": "Throughput (req/sec)",
            "targets": [
              {
                "expr": "sum(rate(http_requests_total[5m]))",
                "legendFormat": "requests/sec"
              }
            ],
            "type": "graph"
          },
          {
            "title": "Error Rate (%)",
            "targets": [
              {
                "expr": "(sum(rate(http_request_failed[5m])) / sum(rate(http_requests_total[5m]))) * 100",
                "legendFormat": "error_rate"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        ]
      },
      {
        "title": "Infrastructure Metrics",
        "height": 250,
        "panels": [
          {
            "title": "CPU Usage (%)",
            "targets": [
              {
                "expr": "avg(100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100))",
                "legendFormat": "CPU"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 80,
                "color": "yellow"
              }
            ]
          },
          {
            "title": "Memory Usage (%)",
            "targets": [
              {
                "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
                "legendFormat": "Memory"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 85,
                "color": "yellow"
              }
            ]
          },
          {
            "title": "Network Throughput (MB/sec)",
            "targets": [
              {
                "expr": "sum(rate(node_network_receive_bytes_total[5m])) / 1000000",
                "legendFormat": "inbound"
              },
              {
                "expr": "sum(rate(node_network_transmit_bytes_total[5m])) / 1000000",
                "legendFormat": "outbound"
              }
            ],
            "type": "graph"
          }
        ]
      },
      {
        "title": "Database Performance",
        "height": 250,
        "panels": [
          {
            "title": "Database Connections (active, idle, waiting)",
            "targets": [
              {
                "expr": "pg_stat_activity_count{state=\"active\"}",
                "legendFormat": "active"
              },
              {
                "expr": "pg_stat_activity_count{state=\"idle\"}",
                "legendFormat": "idle"
              },
              {
                "expr": "pg_stat_activity_count{state=\"idle in transaction\"}",
                "legendFormat": "waiting"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 100,
                "color": "yellow"
              }
            ]
          },
          {
            "title": "Query Performance (p95, p99)",
            "targets": [
              {
                "expr": "histogram_quantile(0.95, rate(pg_query_duration_seconds_bucket[5m]))",
                "legendFormat": "p95"
              },
              {
                "expr": "histogram_quantile(0.99, rate(pg_query_duration_seconds_bucket[5m]))",
                "legendFormat": "p99"
              }
            ],
            "type": "graph",
            "units": "s"
          },
          {
            "title": "Slow Query Count",
            "targets": [
              {
                "expr": "increase(pg_slow_queries_total[5m])",
                "legendFormat": "slow_queries"
              }
            ],
            "type": "graph"
          }
        ]
      },
      {
        "title": "Cache Performance",
        "height": 250,
        "panels": [
          {
            "title": "Cache Hit Rate (%)",
            "targets": [
              {
                "expr": "(redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)) * 100",
                "legendFormat": "hit_rate"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 80,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              }
            ]
          },
          {
            "title": "Redis Memory Usage (%)",
            "targets": [
              {
                "expr": "(redis_memory_used_bytes / redis_memory_max_bytes) * 100",
                "legendFormat": "memory"
              }
            ],
            "type": "graph",
            "thresholds": [
              {
                "value": 80,
                "color": "yellow"
              }
            ]
          },
          {
            "title": "Cache Evictions (per sec)",
            "targets": [
              {
                "expr": "rate(redis_evicted_keys_total[5m])",
                "legendFormat": "evictions"
              }
            ],
            "type": "graph"
          }
        ]
      },
      {
        "title": "Real-time Load & Alerts",
        "height": 200,
        "panels": [
          {
            "title": "Concurrent Users (VUs)",
            "targets": [
              {
                "expr": "avg(k6_vus)",
                "legendFormat": "VUs"
              }
            ],
            "type": "graph"
          },
          {
            "title": "Active Alerts",
            "type": "alertlist",
            "query": "{{severity=~\"warning|critical\"}}"
          }
        ]
      }
    ]
  }
}
