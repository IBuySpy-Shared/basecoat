{
  "name": "@basecoat/copilot-cli-plugin",
  "version": "0.1.0",
  "description": "GitHub Copilot CLI plugin for routing commands to Basecoat agents",
  "keywords": ["github-copilot", "copilot-plugin", "basecoat", "ai-agents", "cli"],
  "repository": {
    "type": "git",
    "url": "https://github.com/IBuySpy-Shared/basecoat.git",
    "directory": "plugins/copilot-cli-plugin"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "basecoat": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0"
  }
}
