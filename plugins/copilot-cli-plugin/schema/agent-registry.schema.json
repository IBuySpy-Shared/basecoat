{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BasecoatAgentRegistry",
  "description": "Schema for the Basecoat agent registry used by the copilot-cli-plugin",
  "type": "object",
  "required": ["version", "generated", "agents"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Registry schema version (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated": {
      "type": "string",
      "description": "ISO 8601 timestamp when this registry was generated",
      "format": "date-time"
    },
    "agents": {
      "type": "object",
      "description": "Map of agent-id to agent entry",
      "additionalProperties": {
        "$ref": "#/definitions/AgentEntry"
      }
    }
  },
  "definitions": {
    "AgentEntry": {
      "type": "object",
      "required": ["id", "name", "description", "file", "keywords", "capabilities", "model", "maturity", "category"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique agent identifier (kebab-case, matches filename without .agent.md)",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "description": "Human-readable agent name"
        },
        "description": {
          "type": "string",
          "description": "One-line description of what the agent does (≤ 120 chars)"
        },
        "file": {
          "type": "string",
          "description": "Relative path to the agent file from repo root",
          "pattern": "^agents/[a-z][a-z0-9-]+\\.agent\\.md$"
        },
        "keywords": {
          "type": "array",
          "description": "Keywords for fuzzy search and routing",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 20
        },
        "capabilities": {
          "type": "array",
          "description": "Capability tags (e.g. backend, frontend, security, infra)",
          "items": { "type": "string" },
          "minItems": 0,
          "maxItems": 10
        },
        "model": {
          "type": "string",
          "description": "Recommended model for this agent",
          "examples": ["claude-sonnet-4.6", "claude-haiku-4.5", "claude-opus-4.5"]
        },
        "maturity": {
          "type": "string",
          "description": "Maturity level of the agent",
          "enum": ["production", "beta", "experimental"]
        },
        "category": {
          "type": "string",
          "description": "Grouping category for display purposes"
        }
      }
    }
  }
}
