#!/usr/bin/env bash

set -euo pipefail

message_file="${1:-}"
if [[ -z "$message_file" || ! -f "$message_file" ]]; then
  echo "commit-msg hook: commit message file not found" >&2
  exit 1
fi

patterns=(
  "-----BEGIN (RSA|EC|OPENSSH|DSA|PRIVATE) KEY-----"
  "gh[pousr]_[A-Za-z0-9]{20,}"
  "AKIA[0-9A-Z]{16}"
  "DefaultEndpointsProtocol=.*AccountKey="
  "(api[_-]?key|secret|client[_-]?secret|password|token)[[:space:]]*[:=][[:space:]]*[^[:space:]]+"
  "[0-9]{3}-[0-9]{2}-[0-9]{4}"
  "[0-9]{4}[- ][0-9]{4}[- ][0-9]{4}[- ][0-9]{4}"
)

for regex in "${patterns[@]}"; do
  if grep -Eiq -- "$regex" "$message_file"; then
    echo "Commit message appears to include sensitive content. Commit blocked." >&2
    echo "Remove secrets/PII from commit message and retry." >&2
    exit 1
  fi
done

exit 0