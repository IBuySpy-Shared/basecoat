{
  "name": "@basecoat/portal-api",
  "version": "1.0.0",
  "description": "Basecoat Portal API - Governance, security audit, and compliance tracking",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:migrate": "typeorm migration:run -d dist/src/config/database.js",
    "db:rollback": "typeorm migration:revert -d dist/src/config/database.js",
    "db:generate": "typeorm migration:generate",
    "health-check": "node -e \"require('http').get('http://localhost:3000/health', (r) => console.log(r.statusCode === 200 ? 'HEALTHY' : 'UNHEALTHY'))\"",
    "seed": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.2",
    "typeorm": "^0.3.17",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.3.3",
    "tsx": "^4.6.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "prettier": "^3.1.0"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
