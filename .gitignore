refresh_token

# Kubernetes secrets
kubeconfig
*.kubeconfig
kube-config

# Docker
.docker/config.json
docker-compose.override.yml

# JetBrains IDE — may contain auth tokens
.idea/

# macOS keychain artifacts
*.keychain

# Node.js — local overrides that may contain secrets
.npmrc
!.npmrc.example
.yarnrc
!.yarnrc.example

# Python
pip-self-check.json

# Gitleaks report output (contains redacted but still sensitive metadata)
gitleaks-report.json
gitleaks-report.sarif

# Dashboard local config cache (secrets stored via gh CLI)
.dashboard-repos-cache.json

