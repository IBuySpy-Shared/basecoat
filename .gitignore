dist/
node_modules/
site/

# =============================================================================
# Secret & credential files — NEVER commit these
# Part of: basecoat Enterprise Governance Framework (Issue #43)
# =============================================================================

# Environment variable files
.env
.env.*
.envrc
!.env.example
!.env.sample
!.env.template

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
id_dsa
id_dsa.*
*.ppk

# Cloud provider credential files
credentials.json
secrets.json
secret.json
service-account.json
service_account.json
*-service-account.json
*_service_account.json
gcloud-credentials.json
application_default_credentials.json

# Azure
azureauth.json
azurecredentials.json
local.settings.json
appsettings.*.json
!appsettings.json
!appsettings.Development.json.example

# AWS
.aws/credentials
.aws/config
aws-credentials.json

# Terraform / OpenTofu state (may contain secrets)
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraformrc
terraform.rc
terraform.lock.hcl
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform logs
*.log

# Lambda function packages (may contain code)
lambda_rotation.zip

# Ansible
*.vault
ansible-vault-password
vault-password.txt

# SSH / GPG
.gnupg/
*.gpg
known_hosts

# Token / secret files
*.token
*.secret
*_token
*_secret
auth_token
access_token
refresh_token

# Kubernetes secrets
kubeconfig
*.kubeconfig
kube-config

# Docker
.docker/config.json
docker-compose.override.yml

# JetBrains IDE — may contain auth tokens
.idea/

# macOS keychain artifacts
*.keychain

# Node.js — local overrides that may contain secrets
.npmrc
!.npmrc.example
.yarnrc
!.yarnrc.example

# Python
pip-self-check.json
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Gitleaks report output (contains redacted but still sensitive metadata)
gitleaks-report.json
gitleaks-report.sarif

# Dashboard local config cache (secrets stored via gh CLI)
.dashboard-repos-cache.json

# =============================================================================
# Session state and accumulated memory — NEVER commit these
# These are org-private: they accumulate from your team's usage of BaseCoat.
# Each org that forks BaseCoat builds their own. They do not travel upstream.
# =============================================================================

# SQLite memory store (docs/SQLITE_MEMORY.md)
*.db
*.sqlite
*.sqlite3
memory.db
memories.db

# Copilot CLI session state (contains turn history, checkpoints, memories)
.copilot/session-state/
.copilot/sessions/

# Memory export/import artifacts
memories.json
memory-export.json
memory-snapshot.json
.memory/

# Any local agent state files
agent-state.json
session-state.json

# Test result artifacts (generated by quality-gate, AB, eval runs)
test-results/

# Code coverage output
coverage/
.nyc_output/

# AI-generated completion artifacts (never commit these)
*_COMPLETION_SUMMARY.txt
*_COMPLETION_SUMMARY.md
WAVE*_DAY*_*.txt
WAVE*_DAY*_*.md
*_STATUS.txt
*_EXECUTIVE_SUMMARY.txt

